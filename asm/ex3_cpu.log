// data (read-only)
  VH6: 006e [0006]: (    6:    6)      	// VH6 = 0x6 (0110)
  VH9: 006f [0009]: (    9:    9)      	// VH9 = 0x9 (1001)
  VHA: 0070 [000a]: (   10:   10)      	// VHA = 0xA (1010)
