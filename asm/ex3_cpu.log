// interrupt entry point
  ST0: 0000 [0000]: (    0:    0)      	// interrupt return address
       0001 [401d]: BUN 01d   (I_HND)	// goto I_HND (interrupt handler)
// program entry point
// initialize data
  INI: 0010 [7800]: CLA              	// AC <- 0
       0011 [3032]: STA 032   (  STT)	// M[STT] <- 0
       0012 [3033]: STA 033   (  SFG)	// M[SFG] <- 0
// IMSK[3:0] : { S_IN, S_OUT, P_IN, P_OUT }
       0013 [2034]: LDA 034   (  VH4)	// AC <- M[VH8] (1000)
       0014 [f010]: IMK              	// IMSK <- (1000) (S_IN enabled)
       0015 [f040]: SIO              	// IOT <- 1 (serial-IO selected)
       0016 [7400]: CLE              
