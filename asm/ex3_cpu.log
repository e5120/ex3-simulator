----------------
label(  ST0) :     0(0x0000)
label(  INI) :    16(0x0010)
label(   L0) :    26(0x001a)
label(  UMK) :    30(0x001e)
label(  CEC) :    37(0x0025)
label(I_HND) :    46(0x002e)
label(  SIN) :    49(0x0031)
label(  POU) :    61(0x003d)
label(  PIN) :    72(0x0048)
label(  SOU) :    84(0x0054)
label(  IRT) :    95(0x005f)
label(   BA) :   102(0x0066)
label(   BE) :   103(0x0067)
label(  SDT) :   104(0x0068)
label(  PDT) :   105(0x0069)
label(  STT) :   106(0x006a)
label(  SFG) :   107(0x006b)
label(  PFG) :   108(0x006c)
label(  MSK) :   109(0x006d)
label(  VH6) :   110(0x006e)
label(  VH9) :   111(0x006f)
label(  VHA) :   112(0x0070)
label(  VM1) :   113(0x0071)
label(  VM4) :   114(0x0072)
----------------
// interrupt entry point
  ST0: 0000 [0000]: (    0:    0)      	// interrupt return address
       0001 [402e]: BUN 02e   (I_HND)	// goto I_HND (interrupt handler)
// program entry point
// initialize data
  INI: 0010 [7800]: CLA              	// AC <- 0
       0011 [306a]: STA 06a   (  STT)	// M[STT] <- 0
       0012 [306b]: STA 06b   (  SFG)	// M[SFG] <- 0
       0013 [306c]: STA 06c   (  PFG)	// M[PFG] <- 0
// IMSK[3:0] : { S_IN, S_OUT, P_IN, P_OUT }
       0014 [2070]: LDA 070   (  VHA)	// AC <- M[VHA] (1010)
       0015 [306d]: STA 06d   (  MSK)	// M[MSK] <- (1010)
       0016 [f010]: IMK              	// IMSK   <- (1010) (S_IN, P_IN enabled)
       0017 [7400]: CLE              
       0018 [7100]: CME              
       0019 [f080]: IST              
//	ION					/ enable interrupt
   L0: 001a [206a]: LDA 06a   (  STT)	// AC <- M[STT]
       001b [7008]: SNA              	// (M[STT] < 0) ? skip next
       001c [401a]: BUN 01a   (   L0)
       001d [7001]: HLT              
//////////// subroutine (update IMSK) ////////
  UMK: 001e [0000]: (    0:    0)      
// arg0 (AC) : unchanged bit mask
// arg1 : added mask bit
       001f [006d]: AND 06d   (  MSK)	// AC <- arg0 & M[MSK]
       0020 [901e]: ADD 01e I (  UMK)	// AC <- AC + M[M[UMK]]
       0021 [306d]: STA 06d   (  MSK)	// M[MSK] <- AC
       0022 [f010]: IMK              	// IMSK <- AC[3:0]
       0023 [601e]: ISZ 01e   (  UMK)	// ++M[UMK]
       0024 [c01e]: BUN 01e I (  UMK)	// return from UMK
//////////// subroutine (check end-character) ////////
  CEC: 0025 [0000]: (    0:    0)      
// arg0 (AC) : output character
// end-character = 0x4 (ctrl-D)
       0026 [1072]: ADD 072   (  VM4)	// AC <- AC - 4
       0027 [7004]: SZA              	// (AC == 0) ? skip next
       0028 [c025]: BUN 025 I (  CEC)	// return from CEC
// output character matches (ctrl-D)
       0029 [2071]: LDA 071   (  VM1)	// AC <- -1
       002a [306a]: STA 06a   (  STT)	// M[STT] <- -1
       002b [7800]: CLA              	// AC <- 0
       002c [f010]: IMK              	// IMASK <- 0 (all interrupts disabled)
       002d [c025]: BUN 025 I (  CEC)	// return from CEC
//////////// interrupt handler /////////
// 1. store AC & E to memory
I_HND: 002e [3066]: STA 066   (   BA)	// M[BA] <- AC	(store AC)
       002f [7040]: CIL              	// AC[0] <- E	(AC[15:1] is not important here...)
       0030 [3067]: STA 067   (   BE)	// M[BE] <- AC	(store E)
// 2. check SFG and S_IN
//_B_,
  SIN: 0031 [206b]: LDA 06b   (  SFG)	// AC <- M[SFG]
       0032 [7004]: SZA              	// (M[SFG] == 0) ? skip next
       0033 [403d]: BUN 03d   (  POU)	// goto POU
       0034 [f040]: SIO              	// IOT <- 1 (serial-IO selected)
       0035 [f200]: SKI              	// (UART_RX ready) ? skip next
       0036 [4048]: BUN 048   (  PIN)	// goto PIN
// S_IN is ready --> update IMSK (disable S_IN, enable P_OUT)
       0037 [206e]: LDA 06e   (  VH6)	// AC <- (0110) (S_OUT, P_IN : unchanged)
       0038 [501e]: BSA 01e   (  UMK)	// call UMK (update IMSK)
       0039 [0001]: (    1:    1)      	// (0001) (P_OUT : enabled)
// read S_IN data
       003a [f800]: INP              	// AC(7:0) <- INPR
       003b [3068]: STA 068   (  SDT)	// M[SDT] <- AC
       003c [606b]: ISZ 06b   (  SFG)	// ++M[SFG]
// 3. check P_OUT
// M[SFG] != 0
  POU: 003d [f020]: PIO              	// IOT <- 0 (parallel-IO selected)
       003e [f100]: SKO              	// (P_OUT ready) ? skip next
       003f [4048]: BUN 048   (  PIN)	// goto PIN
// P_OUT is ready --> update IMSK (disable P_OUT, enable S_IN)
       0040 [206e]: LDA 06e   (  VH6)	// AC <- (0110) (S_OUT, P_IN : unchanged)
       0041 [501e]: BSA 01e   (  UMK)	// call UMK (update IMSK)
       0042 [0008]: (    8:    8)      	// (1000) (S_IN : enabled)
// output to P_OUT
       0043 [2068]: LDA 068   (  SDT)	// AC <- M[SDT]
       0044 [f400]: OUT              	// OUTR <- AC
       0045 [5025]: BSA 025   (  CEC)	// call CEC (check end-character)
       0046 [7800]: CLA              	// AC <- 0
       0047 [306b]: STA 06b   (  SFG)	// M[SFG] <- 0
// 4. check PFG and P_IN
  PIN: 0048 [206c]: LDA 06c   (  PFG)	// AC <- M[PFG]
       0049 [7004]: SZA              	// (M[PFG] == 0) ? skip next
       004a [4054]: BUN 054   (  SOU)	// goto SOU
       004b [f020]: PIO              	// IOT <- 0 (parallel-IO selected)
       004c [f200]: SKI              	// (GP_IN ready) ? skip next
       004d [405f]: BUN 05f   (  IRT)	// goto IRT
// P_IN is ready --> update IMSK (disable P_IN, enable S_OUT)
       004e [206f]: LDA 06f   (  VH9)	// AC <- (1001) (S_IN, P_OUT : unchanged)
       004f [501e]: BSA 01e   (  UMK)	// call UMK (update IMSK)
       0050 [0004]: (    4:    4)      	// (0100) (S_OUT : enabled)
// read P_IN data
       0051 [f800]: INP              	// AC(7:0) <- INPR
       0052 [3069]: STA 069   (  PDT)	// M[PDT] <- AC
       0053 [606c]: ISZ 06c   (  PFG)	// ++M[PFG]
// 5. check S_OUT
// M[PFG] != 0
  SOU: 0054 [f040]: SIO              	// IOT <- 1 (serial-IO selected)
       0055 [f100]: SKO              	// (S_OUT ready) ? skip next
       0056 [405f]: BUN 05f   (  IRT)	// goto IRT
// S_OUT is ready --> update IMSK (disable S_OUT, enable P_IN)
       0057 [206f]: LDA 06f   (  VH9)	// AC <- (1001) (S_IN, P_OUT : unchanged)
       0058 [501e]: BSA 01e   (  UMK)	// call UMK (update IMSK)
       0059 [0002]: (    2:    2)      	// (0010) (P_IN : enabled)
// output to S_OUT
       005a [2069]: LDA 069   (  PDT)	// AC <- M[PDT]
       005b [f400]: OUT              	// OUTR <- AC
       005c [5025]: BSA 025   (  CEC)	// call CEC (check end-character)
       005d [7800]: CLA              	// AC <- 0
       005e [306c]: STA 06c   (  PFG)	// M[PFG] <- 0
// 6. restore AC & E from memory
  IRT: 005f [2067]: LDA 067   (   BE)	// AC <- M[BE]
       0060 [7080]: CIR              	// E <- AC[0]	(restore E)
       0061 [2066]: LDA 066   (   BA)	// AC <- M[BA]	(restore AC)
       0062 [7400]: CLE              
       0063 [7100]: CME              
       0064 [f080]: IST              
//	ION				/ IEN <- 1		(enable interrupt)
       0065 [c000]: BUN 000 I (  ST0)	// indirect return (return address stored in ST0)
// data (no initialization)
   BA: 0066 [0000]: (    0:    0)      	// backup storage for AC during interrupt handling
   BE: 0067 [0000]: (    0:    0)      	// backup storage for  E during interrupt handling
  SDT: 0068 [0000]: (    0:    0)      	// S_IN data
  PDT: 0069 [0000]: (    0:    0)      	// P_IN data
// data (need initialization code)
  STT: 006a [0000]: (    0:    0)      	// state
  SFG: 006b [0000]: (    0:    0)      	// S_IN flag
  PFG: 006c [0000]: (    0:    0)      	// P_IN flag
  MSK: 006d [0000]: (    0:    0)      	// IMSK data
// data (read-only)
  VH6: 006e [0006]: (    6:    6)      	// VH6 = 0x6 (0110)
  VH9: 006f [0009]: (    9:    9)      	// VH9 = 0x9 (1001)
  VHA: 0070 [000a]: (   10:   10)      	// VHA = 0xA (1010)
  VM1: 0071 [ffff]: (   -1:65535)      	// VM1 = -1
  VM4: 0072 [fffc]: (   -4:65532)      	// VM4 = -4
