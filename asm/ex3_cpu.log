       0018 [f080]: IST              
   L0: 0019 [2032]: LDA 032   (  STT)	// AC <- M[STT]
       001a [7008]: SNA              	// (M[STT] < 0) ? skip next
       001b [4019]: BUN 019   (   L0)
       001c [7001]: HLT              
//////////// interrupt handler /////////
// 1. store AC & E to memory
I_HND: 001d [302f]: STA 02f   (   BA)	// M[BA] <- AC	(store AC)
       001e [7040]: CIL              	// AC[0] <- E	(AC[15:1] is not important here...)
       001f [3030]: STA 030   (   BE)	// M[BE] <- AC	(store E)
// 3. check GP_OUT
// M[SFG] != 0
  SOU: 0020 [f100]: SKO              	// (S_OUT ready) ? skip next
       0021 [4028]: BUN 028   (  IRT)	// goto IRT
// output to S_OUT
       0022 [a047]: LDA 047 I (   ST)	// AC <- M[SDT]
       0023 [f400]: OUT              
       0024 [6047]: ISZ 047   (   ST)
       0025 [6038]: ISZ 038   (COUNT)
       0026 [4020]: BUN 020   (  SOU)
       0027 [7001]: HLT              
// 4. restore AC & E from memory
  IRT: 0028 [2030]: LDA 030   (   BE)	// AC <- M[BE]
       0029 [7080]: CIR              	// E <- AC[0]	(restore E)
       002a [202f]: LDA 02f   (   BA)	// AC <- M[BA]	(restore AC)
       002b [7400]: CLE              
       002c [7100]: CME              
       002d [f080]: IST              
       002e [c000]: BUN 000 I (  ST0)	// indirect return (return address stored in ST0)
