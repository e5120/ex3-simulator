----------------
label(  ST0) :     0(0x0000)
label(  INI) :    16(0x0010)
label(   L0) :    27(0x001b)
label(  CEC) :    31(0x001f)
label(I_HND) :    40(0x0028)
label(   TM) :    43(0x002b)
label(TIMER) :    46(0x002e)
label(  SIN) :    53(0x0035)
label(  SOU) :    63(0x003f)
label(  IRT) :    72(0x0048)
label(   BA) :    79(0x004f)
label(   BE) :    80(0x0050)
label(  SDT) :    81(0x0051)
label(  STT) :    82(0x0052)
label(  SFG) :    83(0x0053)
label(  VH4) :    84(0x0054)
label(  VH8) :    85(0x0055)
label(  VM1) :    86(0x0056)
label(  VM4) :    87(0x0057)
label(   CH) :    88(0x0058)
label( TIME) :    89(0x0059)
----------------
// interrupt entry point
  ST0: 0000 [0000]: (    0:    0)      	// interrupt return address
       0001 [4028]: BUN 028   (I_HND)	// goto I_HND (interrupt handler)
// program entry point
// initialize data
  INI: 0010 [7800]: CLA              	// AC <- 0
       0011 [3052]: STA 052   (  STT)	// M[STT] <- 0
       0012 [3053]: STA 053   (  SFG)	// M[SFG] <- 0
// IMSK[3:0] : { S_IN, S_OUT, P_IN, P_OUT }
       0013 [2055]: LDA 055   (  VH8)	// AC <- M[VH8] (1000)
       0014 [f010]: IMK              	// IMSK <- (1000) (S_IN enabled)
       0015 [f040]: SIO              	// IOT <- 1 (serial-IO selected)
//		PIO
       0016 [7400]: CLE              
       0017 [7100]: CME              
       0018 [f080]: IST              
       0019 [2059]: LDA 059   ( TIME)
       001a [f008]: TMR              
   L0: 001b [2052]: LDA 052   (  STT)	// AC <- M[STT]
       001c [7008]: SNA              	// (M[STT] < 0) ? skip next
       001d [401b]: BUN 01b   (   L0)
       001e [7001]: HLT              
//////////// subroutine (check end-character) ////////
// 終了条件・・・ctrl-Dが入力された時、エラー値(-1)を状態変数STTに代入する。
// 　　　　　　　L0のループで状態変数STTがエラー値(-1)を持つと終了する。
  CEC: 001f [0000]: (    0:    0)      
// arg0 (AC) : output character
// end-character = 0x4 (ctrl-D)
       0020 [1057]: ADD 057   (  VM4)	// AC <- AC - 4
       0021 [7004]: SZA              	// (AC == 0) ? skip next
       0022 [c01f]: BUN 01f I (  CEC)	// return from CEC
// output character matches (ctrl-D)
       0023 [2056]: LDA 056   (  VM1)	// AC <- -1
       0024 [3052]: STA 052   (  STT)	// M[STT] <- -1
       0025 [7800]: CLA              	// AC <- 0
       0026 [f010]: IMK              	// IMSK <- 0 (all interrupts disabled)
       0027 [c01f]: BUN 01f I (  CEC)	// return from CEC
//////////// interrupt handler /////////
// 1. store AC & E to memory
I_HND: 0028 [304f]: STA 04f   (   BA)	// M[BA] <- AC	(store AC)
       0029 [7040]: CIL              	// AC[0] <- E	(AC[15:1] is not important here...)
       002a [3050]: STA 050   (   BE)	// M[BE] <- AC	(store E)
   TM: 002b [f004]: SKT              
       002c [4035]: BUN 035   (  SIN)
       002d [402e]: BUN 02e   (TIMER)
TIMER: 002e [2059]: LDA 059   ( TIME)
       002f [f008]: TMR              
       0030 [2054]: LDA 054   (  VH4)
       0031 [f010]: IMK              
       0032 [2058]: LDA 058   (   CH)
       0033 [3051]: STA 051   (  SDT)
       0034 [403f]: BUN 03f   (  SOU)
// 2. check SFG and S_IN
  SIN: 0035 [2053]: LDA 053   (  SFG)	// AC <- M[SFG]
       0036 [7004]: SZA              	// (M[SFG] == 0) ? skip next
       0037 [403f]: BUN 03f   (  SOU)	// goto SOU
       0038 [f200]: SKI              	// (S_IN ready) ? skip next
       0039 [4048]: BUN 048   (  IRT)	// goto IRT
// S_IN is ready --> update IMSK (disable S_IN, enable S_OUT)
       003a [2054]: LDA 054   (  VH4)	// AC   <- (0100)
       003b [f010]: IMK              	// IMSK <- (0100) (enable S_OUT)
// read S_IN data
       003c [f800]: INP              	// AC(7:0) <- INPR
       003d [3051]: STA 051   (  SDT)	// M[SDT] <- AC
       003e [6053]: ISZ 053   (  SFG)	// ++M[SFG]
// 3. check GP_OUT
// M[SFG] != 0
  SOU: 003f [f100]: SKO              	// (S_OUT ready) ? skip next
       0040 [4048]: BUN 048   (  IRT)	// goto IRT
// S_OUT is ready --> update IMSK (disable S_OUT, enable S_IN)
       0041 [2055]: LDA 