  VH8: 0035 [0008]: (    8:    8)      	// VHA = 0x8 (1000)
  VM1: 0036 [ffff]: (   -1:65535)      	// VM1 = -1
  VM4: 0037 [fffc]: (   -4:65532)      	// VM4 = -4
