// interrupt entry point
  ST0: 0000 [001c]: (   28:   28)      	// interrupt return address
//////////// subroutine (update IMSK) ////////
  UMK: 001e [005a]: (   90:  'Z')      
//////////// subroutine (check end-character) ////////
  CEC: 0025 [005d]: (   93:  ']')      
       0039 [0001]: (    1:    1)      	// (0001) (P_OUT : enabled)
       0042 [0008]: (    8:    8)      	// (1000) (S_IN : enabled)
       0050 [0004]: (    4:    4)      	// (0100) (S_OUT : enabled)
       0059 [0002]: (    2:    2)      	// (0010) (P_IN : enabled)
// data (no initialization)
   BA: 0066 [0000]: (    0:    0)      	// backup storage for AC during interrupt handling
   BE: 0067 [0001]: (    1:    1)      	// backup storage for  E during interrupt handling
  SDT: 0068 [006f]: (  111:  'o')      	// S_IN data
  PDT: 0069 [0004]: (    4:    4)      	// P_IN data
// data (need initialization code)
  STT: 006a [ffff]: (   -1:65535)      	// state
