/// Verilog Memory Probe File (.prb) generated by ./ex3_asm

/// bit[31:28] : memory type (0000 : data, 1111 : end-of-memory
/// bit[27:16] : address
/// bit[15:0]  : data

// interrupt entry point
0000001a	///	  ST0: 0000 [001a]: (   26:   26)      	// interrupt return address
//////////// subroutine (check end-character) ////////
// 終了条件・・・ctrl-Dが入力された時、エラー値(-1)を状態変数STTに代入する。
// 　　　　　　　L0のループで状態変数STTがエラー値(-1)を持つと終了する。
001d003a	///	  CEC: 001d [003a]: (   58:  ':')      
// data (no initialization)
00430000	///	   BA: 0043 [0000]: (    0:    0)      	// backup storage for AC during interrupt handling
00440001	///	   BE: 0044 [0001]: (    1:    1)      	// backup storage for  E during interrupt handling
00450004	///	  SDT: 0045 [0004]: (    4:    4)      	// S_IN data
// data (need initialization code)
0046ffff	///	  STT: 0046 [ffff]: (   -1:65535)      	// state
00470000	///	  SFG: 0047 [0000]: (    0:    0)      	// S_IN flag
// data (read-only)
00480004	///	  VH4: 0048 [0004]: (    4:    4)      	// VH4 = 0x4 (0100)
00490008	///	  VH8: 0049 [0008]: (    8:    8)      	// VHA = 0x8 (1000)
//VH4,	HEX 1     / VH4 = 0x1 (0001)
//VH8,	HEX 2     / VHA = 0x8 (0010)
004affff	///	  VM1: 004a [ffff]: (   -1:65535)      	// VM1 = -1
004bfffc	///	  VM4: 004b [fffc]: (   -4:65532)      	// VM4 = -4
f0000000	///	end-of-memory
