/// Verilog Memory Probe File (.prb) generated by ./ex3_asm

/// bit[31:28] : memory type (0000 : data, 1111 : end-of-memory
/// bit[27:16] : address
/// bit[15:0]  : data

// interrupt entry point
00000000	///	  ST0: 0000 [0000]: (    0:    0)      	// interrupt return address
// data (no initialization)
003a0000	///	   BA: 003a [0000]: (    0:    0)      	// backup storage for AC during interrupt handling
003b0000	///	   BE: 003b [0000]: (    0:    0)      	// backup storage for  E during interrupt handling
// data (need initialization code)
003c0000	///	  STT: 003c [0000]: (    0:    0)      	// state
// data (read-only)
003d0004	///	  VH4: 003d [0004]: (    4:    4)      	// VH4 = 0x4 (0100)
003effff	///	  VM1: 003e [ffff]: (   -1:65535)      	// VM1 = -1
003ffffc	///	  VM4: 003f [fffc]: (   -4:65532)      	// VM4 = -4
00400030	///	   AD: 0040 [0030]: (   48:  '0')      	// ASCII '0'
00410000	///	  CNT: 0041 [0000]: (    0:    0)      	// counter
0042fff6	///	 CNT2: 0042 [fff6]: (  -10:65526)      	// counter2
00430064	///	 TIME: 0043 [0064]: (  100:  'd')      	// timer(range : 1 ~ 999[ms])
f0000000	///	end-of-memory
